# App
NODE_ENV=development
UPLOADS_DIR="/uploads"

# Database
DATABASE_URL="postgresql://admin:your_password_here@localhost:5432/filo_db?schema=public"
POSTGRES_USER=admin
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=filo_db

# Auth.js / NextAuth
AUTH_SECRET="replace_with_a_strong_secret"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST=true
# Optional: enables the database-independent admin login in production.
# In development, admin login can still use POSTGRES_PASSWORD.
ADMIN_BOOTSTRAP_PASSWORD=""

# Compatibility aliases (some tooling still expects NEXTAUTH_*)
NEXTAUTH_SECRET="replace_with_a_strong_secret"
NEXTAUTH_URL="http://localhost:3000"

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Sirket {
  id              String      @id @default(cuid())
  ad              String
  vergiNo         String?
  olusturmaTarihi DateTime    @default(now())
  bulunduguIl     String      @default("BURSA")
  araclar         Arac[]
  kullanicilar    Kullanici[]
}

model Arac {
  id                   String             @id @default(cuid())
  plaka                String?            @unique
  marka                String
  model                String
  yil                  Int
  guncelKm             Int                @default(0)
  hgsNo                String?
  ruhsatSeriNo         String?
  durum                AracDurumu         @default(AKTIF)
  kullaniciId          String?            @unique
  sirketId             String?
  olusturmaTarihi      DateTime           @default(now())
  guncellemeTarihi     DateTime           @default(now()) @updatedAt
  kategori             AracKategori       @default(BINEK)
  saseNo               String?
  deletedAt            DateTime?
  deletedBy            String?
  aciklama             String?
  bedel                Float?
  calistigiKurum       String?
  motorNo              String?
  bulunduguIl          String             @default("BURSA")
  kullanici            Kullanici?         @relation(fields: [kullaniciId], references: [id])
  sirket               Sirket?            @relation(fields: [sirketId], references: [id])
  arizaKayitlari       ArizaKaydi[]
  bakimlar             Bakim[]
  cezalar              Ceza[]
  dokumanlar           Dokuman[]
  hgsYuklemeler        HgsYukleme[]
  kasko                Kasko[]
  masraflar            Masraf[]
  muayene              Muayene[]
  kullaniciGecmisi     KullaniciZimmet[]
  trafikSigortasi      TrafikSigortasi[]
  yakitlar             Yakit[]
  yakitTankHareketleri YakitTankHareket[]

  @@index([plaka])
  @@index([durum])
  @@index([sirketId])
  @@index([deletedAt])
}

model Kullanici {
  id                   String             @id @default(cuid())
  ad                   String
  soyad                String
  telefon              String?
  tcNo                 String?            @unique
  calistigiKurum       String?
  eposta               String?            @unique
  sifre                String?
  rol                  Rol                @default(PERSONEL)
  sirketId             String?
  onayDurumu           OnayDurumu         @default(BEKLIYOR)
  deletedAt            DateTime?
  deletedBy            String?
  arac                 Arac?
  arizaKayitlari       ArizaKaydi[]       @relation("ArizaSoforRelation")
  bakimKayitlari       Bakim[]            @relation("BakimSoforRelation")
  cezalar              Ceza[]             @relation("CezaSoforRelation")
  hesap                Hesap?
  sirket               Sirket?            @relation(fields: [sirketId], references: [id])
  zimmetler            KullaniciZimmet[]
  yakitKayitlari       Yakit[]            @relation("YakitSoforRelation")
  yakitTankHareketleri YakitTankHareket[]

  @@index([sirketId])
  @@index([deletedAt])
  @@map("Personel")
}

model KullaniciZimmet {
  id          String    @id @default(cuid())
  aracId      String
  kullaniciId String
  baslangic   DateTime  @default(now())
  bitis       DateTime?
  baslangicKm Int
  bitisKm     Int?
  notlar      String?
  saseNo      String?
  arac        Arac      @relation(fields: [aracId], references: [id])
  kullanici   Kullanici @relation(fields: [kullaniciId], references: [id])

  @@index([aracId])
  @@index([kullaniciId])
  @@map("PersonelZimmet")
}

model Hesap {
  id               String    @id @default(cuid())
  personelId       String    @unique
  kullaniciAdi     String    @unique
  sifreHash        String
  aktifMi          Boolean   @default(true)
  sonGirisTarihi   DateTime?
  olusturmaTarihi  DateTime  @default(now())
  guncellemeTarihi DateTime  @updatedAt
  personel         Kullanici @relation(fields: [personelId], references: [id], onDelete: Cascade)

  @@index([aktifMi])
}

model TrafikSigortasi {
  id              String   @id @default(cuid())
  sirket          String?
  policeNo        String?
  baslangicTarihi DateTime
  bitisTarihi     DateTime
  tutar           Float?
  aktifMi         Boolean  @default(true)
  aracId          String
  sirketId        String?
  acente          String?
  saseNo          String?
  arac            Arac     @relation(fields: [aracId], references: [id])

  @@index([aracId])
  @@index([sirketId])
}

model Kasko {
  id              String   @id @default(cuid())
  sirket          String?
  policeNo        String?
  baslangicTarihi DateTime
  bitisTarihi     DateTime
  tutar           Float?
  aktifMi         Boolean  @default(true)
  aracId          String
  sirketId        String?
  acente          String?
  saseNo          String?
  arac            Arac     @relation(fields: [aracId], references: [id])

  @@index([aracId])
  @@index([sirketId])
}

model Muayene {
  id               String   @id @default(cuid())
  muayeneTarihi    DateTime
  gecerlilikTarihi DateTime
  aktifMi          Boolean  @default(true)
  aracId           String
  sirketId         String?
  km               Int?
  tutar            Float?
  gectiMi          Boolean  @default(true)
  saseNo           String?
  odendiMi         Boolean  @default(false)
  arac             Arac     @relation(fields: [aracId], references: [id])

  @@index([aracId])
  @@index([sirketId])
}

model Bakim {
  id              String         @id @default(cuid())
  bakimTarihi     DateTime
  yapilanKm       Int
  sonrakiBakimKm  Int?
  servisAdi       String?
  yapilanIslemler String?
  tutar           Float          @default(0)
  tur             BakimTuru      @default(PERIYODIK)
  aracId          String?
  sirketId        String?
  kategori        ServisKategori @default(PERIYODIK_BAKIM)
  saseNo          String?
  deletedAt       DateTime?
  deletedBy       String?
  arizaSikayet    String?
  degisenParca    String?
  islemYapanFirma String?
  plaka           String?
  odendiMi        Boolean        @default(false)
  soforId         String?
  arizaKaydi      ArizaKaydi?
  arac            Arac?          @relation(fields: [aracId], references: [id])
  sofor           Kullanici?     @relation("BakimSoforRelation", fields: [soforId], references: [id])

  @@index([plaka])
  @@index([aracId])
  @@index([soforId])
  @@index([sirketId])
  @@index([deletedAt])
}

model ArizaKaydi {
  id                String           @id @default(cuid())
  aracId            String
  soforId           String?          @map("kullaniciId")
  sirketId          String?
  bakimId           String?          @unique
  aciklama          String
  oncelik           ArizaOncelik     @default(ORTA)
  durum             ArizaKaydiDurumu @default(ACIK)
  km                Int?
  servisAdi         String?
  yapilanIslemler   String?
  tutar             Float            @default(0)
  bildirimTarihi    DateTime         @default(now())
  serviseSevkTarihi DateTime?
  kapanisTarihi     DateTime?
  olusturmaTarihi   DateTime         @default(now())
  guncellemeTarihi  DateTime         @default(now()) @updatedAt
  arac              Arac             @relation(fields: [aracId], references: [id])
  bakim             Bakim?           @relation(fields: [bakimId], references: [id])
  sofor             Kullanici?       @relation("ArizaSoforRelation", fields: [soforId], references: [id])

  @@index([aracId])
  @@index([soforId])
  @@index([sirketId])
  @@index([durum])
  @@index([bildirimTarihi])
}

model Ceza {
  id             String     @id @default(cuid())
  tarih          DateTime   @map("cezaTarihi")
  tutar          Float
  aciklama       String?
  odendiMi       Boolean    @default(false)
  aracId         String
  soforId        String?    @map("kullaniciId")
  sirketId       String?
  km             Int?
  sonOdemeTarihi DateTime?
  plaka          String?
  cezaMaddesi    String     @default("Belirtilmedi")
  saseNo         String?
  deletedAt      DateTime?
  deletedBy      String?
  arac           Arac       @relation(fields: [aracId], references: [id])
  kullanici      Kullanici? @relation("CezaSoforRelation", fields: [soforId], references: [id])

  @@index([plaka])
  @@index([soforId])
  @@index([aracId])
  @@index([sirketId])
  @@index([deletedAt])
}

model Masraf {
  id        String           @id @default(cuid())
  tarih     DateTime         @default(now())
  tur       MasrafKategorisi
  tutar     Float
  aracId    String
  aciklama  String?
  sirketId  String?
  saseNo    String?
  deletedAt DateTime?
  deletedBy String?
  arac      Arac             @relation(fields: [aracId], references: [id])

  @@index([aracId])
  @@index([sirketId])
  @@index([deletedAt])
}

model Yakit {
  id           String            @id @default(cuid())
  tarih        DateTime          @default(now())
  litre        Float
  tutar        Float
  km           Int
  istasyon     String?
  aracId       String
  sirketId     String?
  odemeYontemi OdemeYontemi      @default(NAKIT)
  saseNo       String?
  odendiMi     Boolean           @default(false)
  endeks       Int?
  soforId      String?
  arac         Arac              @relation(fields: [aracId], references: [id])
  sofor        Kullanici?        @relation("YakitSoforRelation", fields: [soforId], references: [id])
  tankHareketi YakitTankHareket?

  @@index([aracId])
  @@index([sirketId])
  @@index([tarih])
  @@index([soforId])
}

model YakitTank {
  id               String             @id @default(cuid())
  ad               String
  kapasiteLitre    Float
  mevcutLitre      Float              @default(0)
  birimMaliyet     Float              @default(0)
  aktifMi          Boolean            @default(true)
  olusturmaTarihi  DateTime           @default(now())
  guncellemeTarihi DateTime           @default(now()) @updatedAt
  hedefHareketler  YakitTankHareket[] @relation("YakitTankHedef")
  hareketler       YakitTankHareket[] @relation("YakitTankKaynak")

  @@index([aktifMi])
}

model YakitTankHareket {
  id              String              @id @default(cuid())
  tip             YakitTankHareketTip
  tarih           DateTime            @default(now())
  litre           Float
  birimMaliyet    Float
  toplamTutar     Float
  tankId          String
  hedefTankId     String?
  aracId          String?
  yakitId         String?             @unique
  istasyon        String?
  km              Int?
  aciklama        String?
  olusturmaTarihi DateTime            @default(now())
  endeks          Int?
  soforId         String?
  arac            Arac?               @relation(fields: [aracId], references: [id])
  hedefTank       YakitTank?          @relation("YakitTankHedef", fields: [hedefTankId], references: [id])
  sofor           Kullanici?          @relation(fields: [soforId], references: [id])
  tank            YakitTank           @relation("YakitTankKaynak", fields: [tankId], references: [id])
  yakit           Yakit?              @relation(fields: [yakitId], references: [id])

  @@index([tip])
  @@index([tarih])
  @@index([tankId])
  @@index([hedefTankId])
  @@index([aracId])
  @@index([soforId])
}

model HgsYukleme {
  id       String   @id @default(cuid())
  tarih    DateTime @default(now())
  etiketNo String?
  tutar    Float
  aracId   String
  sirketId String?
  km       Int?
  saseNo   String?
  arac     Arac     @relation(fields: [aracId], references: [id])

  @@index([aracId])
  @@index([sirketId])
  @@index([tarih])
}

model ActivityLog {
  id         String             @id @default(cuid())
  actionType ActivityActionType
  entityType ActivityEntityType
  entityId   String
  summary    String
  metadata   Json?
  userId     String?
  companyId  String?
  createdAt  DateTime           @default(now())

  @@index([actionType])
  @@index([entityType])
  @@index([entityId])
  @@index([companyId])
  @@index([userId])
  @@index([createdAt])
}

model Dokuman {
  id            String      @id @default(cuid())
  ad            String
  dosyaUrl      String
  tur           DokumanTuru
  yuklemeTarihi DateTime    @default(now())
  aracId        String
  sirketId      String?
  saseNo        String?
  deletedAt     DateTime?
  deletedBy     String?
  arac          Arac        @relation(fields: [aracId], references: [id])

  @@index([aracId])
  @@index([sirketId])
  @@index([deletedAt])
}

enum Rol {
  ADMIN
  YETKILI
  PERSONEL
  TEKNIK
}

enum AracDurumu {
  BOSTA
  AKTIF
  SERVISTE
  YEDEK
  ARIZALI
}

enum AracKategori {
  BINEK
  SANTIYE
}

enum MasrafKategorisi {
  YAKIT
  HGS_YUKLEME
  YIKAMA
  AKSESUAR
  DIGER
  BAKIM_ONARIM
  LASTIK
  TEMIZLIK
  OTOPARK
  KOPRU_OBO
}

enum DokumanTuru {
  RUHSAT
  SIGORTA
  KASKO
  SERVIS_FATURA
  DIGER
}

enum BakimTuru {
  PERIYODIK
  ARIZA
  KAPORTA
}

enum ServisKategori {
  PERIYODIK_BAKIM
  ARIZA
}

enum ArizaKaydiDurumu {
  ACIK
  SERVISTE
  TAMAMLANDI
  IPTAL
}

enum ArizaOncelik {
  DUSUK
  ORTA
  YUKSEK
  KRITIK
}

enum OnayDurumu {
  BEKLIYOR
  ONAYLANDI
  REDDEDILDI
}

enum OdemeYontemi {
  NAKIT
  TASIT_TANIMA
}

enum YakitTankHareketTip {
  ALIM
  CIKIS
  TRANSFER
}

enum ActivityActionType {
  CREATE
  UPDATE
  DELETE
  RESTORE
  ARCHIVE
  LOGIN_SUCCESS
  LOGIN_FAILURE
  ROLE_CHANGE
  STATUS_CHANGE
}

enum ActivityEntityType {
  ARAC
  MASRAF
  BAKIM
  DOKUMAN
  CEZA
  KULLANICI
  OTURUM
  DIGER
  TEDARKICI
}

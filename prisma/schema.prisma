generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Sirket {
  id           String      @id @default(cuid())
  ad           String
  bulunduguIl  iller       @default(BURSA)
  vergiNo      String?
  kullanicilar Kullanici[]
  araclar      Arac[]

  olusturmaTarihi DateTime @default(now())
}

model Arac {
  id           String       @id @default(cuid())
  plaka        String       @unique
  marka        String
  model        String
  yil          Int
  bulunduguIl  iller        @default(BURSA)
  guncelKm     Int          @default(0)
  hgsNo        String?
  ruhsatSeriNo String?
  saseNo       String?
  durum        AracDurumu   @default(AKTIF)
  kategori     AracKategori @default(BINEK)

  // Mevcut Şoför (1-1 Zimmet)
  kullanici   Kullanici? @relation(fields: [kullaniciId], references: [id])
  kullaniciId String?    @unique

  // Şirket
  sirket   Sirket? @relation(fields: [sirketId], references: [id])
  sirketId String?

  // İlişkiler
  trafikSigortasi  TrafikSigortasi[]
  kasko            Kasko[]
  muayene          Muayene[]
  bakimlar         Bakim[]
  cezalar          Ceza[]
  masraflar        Masraf[]
  kullaniciGecmisi KullaniciZimmet[]
  yakitlar         Yakit[]
  arizalar         Ariza[]
  dokumanlar       Dokuman[]
  hgsYuklemeler    HgsYukleme[]

  olusturmaTarihi  DateTime @default(now())
  guncellemeTarihi DateTime @default(now()) @updatedAt
  deletedAt        DateTime?
  deletedBy        String?

  @@index([plaka])
  @@index([durum])
  @@index([sirketId])
  @@index([deletedAt])
}

model Kullanici {
  id      String  @id @default(cuid())
  ad      String
  soyad   String
  telefon String?
  tcNo    String? @unique
  sehir   iller?
  eposta  String? @unique
  sifre   String?
  rol     Rol     @default(SOFOR)

  onayDurumu OnayDurumu @default(BEKLIYOR)
  deletedAt  DateTime?
  deletedBy  String?

  sirket   Sirket? @relation(fields: [sirketId], references: [id])
  sirketId String?

  arac           Arac? // Mevcut zimmetli araç
  zimmetler      KullaniciZimmet[] // Geçmiş tüm zimmet kayıtları
  cezalar        Ceza[]            @relation("CezaSoforRelation")
  yakitKayitlari Yakit[]           @relation("YakitSoforRelation")

  @@index([sirketId])
  @@index([deletedAt])
}

model KullaniciZimmet {
  id          String    @id @default(cuid())
  arac        Arac      @relation(fields: [aracId], references: [id])
  aracId      String
  saseNo      String?
  kullanici   Kullanici @relation(fields: [kullaniciId], references: [id])
  kullaniciId String
  baslangic   DateTime  @default(now())
  bitis       DateTime?
  baslangicKm Int // Aracı teslim aldığı KM
  bitisKm     Int? // Aracı teslim ettiği KM
  notlar      String?

  @@index([aracId])
  @@index([kullaniciId])
}

model TrafikSigortasi {
  id              String   @id @default(cuid())
  sirket          String?
  acente          String?
  policeNo        String?
  baslangicTarihi DateTime
  bitisTarihi     DateTime
  tutar           Float?
  aktifMi         Boolean  @default(true)

  arac     Arac    @relation(fields: [aracId], references: [id])
  aracId   String
  saseNo   String?
  sirketId String?
  deletedAt DateTime?
  deletedBy String?

  @@index([aracId])
  @@index([sirketId])
  @@index([deletedAt])
}

model Kasko {
  id              String   @id @default(cuid())
  sirket          String?
  acente          String?
  policeNo        String?
  baslangicTarihi DateTime
  bitisTarihi     DateTime
  tutar           Float?
  aktifMi         Boolean  @default(true)

  arac     Arac    @relation(fields: [aracId], references: [id])
  aracId   String
  saseNo   String?
  sirketId String?

  @@index([aracId])
  @@index([sirketId])
}

model Muayene {
  id               String   @id @default(cuid())
  muayeneTarihi    DateTime
  gecerlilikTarihi DateTime
  tutar            Float?
  gectiMi          Boolean  @default(true)
  km               Int? // Muayene anındaki KM
  aktifMi          Boolean  @default(true)

  arac     Arac    @relation(fields: [aracId], references: [id])
  aracId   String
  saseNo   String?
  sirketId String?

  @@index([aracId])
  @@index([sirketId])
}

model Bakim {
  id              String         @id @default(cuid())
  bakimTarihi     DateTime
  yapilanKm       Int
  sonrakiBakimKm  Int?
  servisAdi       String?
  yapilanIslemler String?        @db.Text
  tutar           Float          @default(0)
  kategori        ServisKategori @default(PERIYODIK_BAKIM)
  tur             BakimTuru      @default(PERIYODIK)

  arac     Arac    @relation(fields: [aracId], references: [id])
  aracId   String
  saseNo   String?
  sirketId String?
  deletedAt DateTime?
  deletedBy String?

  @@index([aracId])
  @@index([sirketId])
  @@index([deletedAt])
}

model Ceza {
  id             String    @id @default(cuid())
  plaka          String?
  soforId        String?   @map("kullaniciId")
  tarih          DateTime  @map("cezaTarihi")
  tutar          Float
  cezaMaddesi    String    @default("Belirtilmedi")
  aciklama       String?
  km             Int? // Ceza anındaki KM (Opsiyonel)
  sonOdemeTarihi DateTime?
  odendiMi       Boolean   @default(false)
  aracId         String
  saseNo         String?
  sirketId       String?
  deletedAt      DateTime?
  deletedBy      String?

  kullanici Kullanici? @relation("CezaSoforRelation", fields: [soforId], references: [id])
  arac      Arac       @relation(fields: [aracId], references: [id])

  @@index([plaka])
  @@index([soforId])
  @@index([aracId])
  @@index([sirketId])
  @@index([deletedAt])
}

model Masraf {
  id       String           @id @default(cuid())
  tarih    DateTime         @default(now())
  tur      MasrafKategorisi
  tutar    Float
  aciklama String?

  arac     Arac    @relation(fields: [aracId], references: [id])
  aracId   String
  saseNo   String?
  sirketId String?
  deletedAt DateTime?
  deletedBy String?

  @@index([aracId])
  @@index([sirketId])
  @@index([deletedAt])
}

model Yakit {
  id           String       @id @default(cuid())
  tarih        DateTime     @default(now())
  litre        Float
  tutar        Float
  km           Int // Yakıt alındığı andaki KM
  istasyon     String?
  odemeYontemi OdemeYontemi @default(NAKIT)
  soforId      String?

  arac     Arac       @relation(fields: [aracId], references: [id])
  sofor    Kullanici? @relation("YakitSoforRelation", fields: [soforId], references: [id])
  aracId   String
  saseNo   String?
  sirketId String?

  @@index([aracId])
  @@index([sirketId])
  @@index([tarih])
  @@index([soforId])
}

model HgsYukleme {
  id       String   @id @default(cuid())
  tarih    DateTime @default(now())
  etiketNo String?
  tutar    Float
  km       Int? // Yükleme anındaki KM

  arac     Arac    @relation(fields: [aracId], references: [id])
  aracId   String
  saseNo   String?
  sirketId String?

  @@index([aracId])
  @@index([sirketId])
  @@index([tarih])
}

model Ariza {
  id           String      @id @default(cuid())
  aciklama     String
  arizaTarihi  DateTime    @default(now())
  durum        ArizaDurumu @default(ACIK)
  servis       String?
  tahminiTutar Float?

  arac     Arac    @relation(fields: [aracId], references: [id])
  aracId   String
  saseNo   String?
  sirketId String?

  @@index([aracId])
  @@index([sirketId])
}

model ActivityLog {
  id         String             @id @default(cuid())
  actionType ActivityActionType
  entityType ActivityEntityType
  entityId   String
  summary    String
  metadata   Json?
  userId     String?
  companyId  String?
  createdAt  DateTime           @default(now())

  @@index([actionType])
  @@index([entityType])
  @@index([entityId])
  @@index([companyId])
  @@index([userId])
  @@index([createdAt])
}

model Dokuman {
  id            String      @id @default(cuid())
  ad            String
  dosyaUrl      String
  tur           DokumanTuru
  yuklemeTarihi DateTime    @default(now())

  arac     Arac    @relation(fields: [aracId], references: [id])
  aracId   String
  saseNo   String?
  sirketId String?
  deletedAt DateTime?
  deletedBy String?

  @@index([aracId])
  @@index([sirketId])
  @@index([deletedAt])
}

// ENUMLAR
enum Rol {
  ADMIN
  YONETICI
  MUDUR
  MUHASEBECI
  SOFOR
}

enum AracDurumu {
  BOSTA
  AKTIF
  SERVISTE
  YEDEK
  ARIZALI
}

enum AracKategori {
  IS_MAKINESI
  KAMYON_TIR
  BINEK
}

enum MasrafKategorisi {
  YAKIT
  HGS_YUKLEME
  YIKAMA
  AKSESUAR
  BAKIM_ONARIM
  LASTIK
  TEMIZLIK
  OTOPARK
  KOPRU_OBO
  DIGER
}

enum ArizaDurumu {
  ACIK
  TAMIRDE
  COZULDU
  PARCA_BEKLIYOR
}

enum DokumanTuru {
  RUHSAT
  SIGORTA
  KASKO
  SERVIS_FATURA
  DIGER
}

enum BakimTuru {
  PERIYODIK
  ARIZA
  KAPORTA
}

enum ServisKategori {
  PERIYODIK_BAKIM
  ARIZA
}

enum iller {
  İSTANBUL
  BURSA
  ŞANLIURFA
  ANKARA
  DİĞER
}

enum OnayDurumu {
  BEKLIYOR
  ONAYLANDI
  REDDEDILDI
}

enum OdemeYontemi {
  TASIT_TANIMA
  NAKIT
}

enum ActivityActionType {
  CREATE
  UPDATE
  DELETE
  RESTORE
  ARCHIVE
  LOGIN_SUCCESS
  LOGIN_FAILURE
  ROLE_CHANGE
  STATUS_CHANGE
}

enum ActivityEntityType {
  ARAC
  MASRAF
  BAKIM
  DOKUMAN
  CEZA
  KULLANICI
  OTURUM
  DIGER
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Sirket {
  id              String      @id @default(cuid())
  ad              String
  bulunduguIl     iller       @default(BURSA)
  vergiNo         String?
  olusturmaTarihi DateTime    @default(now())
  araclar         Arac[]
  kullanicilar    Kullanici[]
}

model Arac {
  id               String            @id @default(cuid())
  plaka            String            @unique
  marka            String
  model            String
  yil              Int
  bulunduguIl      iller             @default(BURSA)
  guncelKm         Int               @default(0)
  hgsNo            String?
  ruhsatSeriNo     String?
  durum            AracDurumu        @default(AKTIF)
  kullaniciId      String?           @unique
  sirketId         String?
  olusturmaTarihi  DateTime          @default(now())
  guncellemeTarihi DateTime          @default(now()) @updatedAt
  kategori         AracKategori      @default(BINEK)
  saseNo           String?
  deletedAt        DateTime?
  deletedBy        String?
  kullanici        Kullanici?        @relation(fields: [kullaniciId], references: [id])
  sirket           Sirket?           @relation(fields: [sirketId], references: [id])
  bakimlar         Bakim[]
  arizaKayitlari   ArizaKaydi[]
  cezalar          Ceza[]
  dokumanlar       Dokuman[]
  hgsYuklemeler    HgsYukleme[]
  kasko            Kasko[]
  masraflar        Masraf[]
  muayene          Muayene[]
  kullaniciGecmisi KullaniciZimmet[]
  trafikSigortasi  TrafikSigortasi[]
  yakitlar         Yakit[]

  @@index([plaka])
  @@index([durum])
  @@index([sirketId])
  @@index([deletedAt])
}

model Kullanici {
  id             String            @id @default(cuid())
  ad             String
  soyad          String
  telefon        String?
  tcNo           String?           @unique
  sehir          iller?
  eposta         String?           @unique
  sifre          String?
  rol            Rol               @default(SOFOR)
  sirketId       String?
  onayDurumu     OnayDurumu        @default(BEKLIYOR)
  deletedAt      DateTime?
  deletedBy      String?
  arac           Arac?
  arizaKayitlari ArizaKaydi[]      @relation("ArizaSoforRelation")
  cezalar        Ceza[]            @relation("CezaSoforRelation")
  hesap          Hesap?
  sirket         Sirket?           @relation(fields: [sirketId], references: [id])
  zimmetler      KullaniciZimmet[]
  yakitKayitlari Yakit[]           @relation("YakitSoforRelation")

  @@index([sirketId])
  @@index([deletedAt])
  @@map("Personel")
}

model KullaniciZimmet {
  id          String    @id @default(cuid())
  aracId      String
  kullaniciId String
  baslangic   DateTime  @default(now())
  bitis       DateTime?
  baslangicKm Int
  bitisKm     Int?
  notlar      String?
  saseNo      String?
  arac        Arac      @relation(fields: [aracId], references: [id])
  kullanici   Kullanici @relation(fields: [kullaniciId], references: [id])

  @@index([aracId])
  @@index([kullaniciId])
  @@map("PersonelZimmet")
}

model Hesap {
  id               String    @id @default(cuid())
  personelId       String    @unique
  kullaniciAdi     String    @unique
  sifreHash        String
  aktifMi          Boolean   @default(true)
  sonGirisTarihi   DateTime?
  olusturmaTarihi  DateTime  @default(now())
  guncellemeTarihi DateTime  @updatedAt
  personel         Kullanici @relation(fields: [personelId], references: [id], onDelete: Cascade)

  @@index([aktifMi])
}

model TrafikSigortasi {
  id              String   @id @default(cuid())
  sirket          String?
  policeNo        String?
  baslangicTarihi DateTime
  bitisTarihi     DateTime
  tutar           Float?
  aktifMi         Boolean  @default(true)
  aracId          String
  sirketId        String?
  acente          String?
  saseNo          String?
  arac            Arac     @relation(fields: [aracId], references: [id])

  @@index([aracId])
  @@index([sirketId])
}

model Kasko {
  id              String   @id @default(cuid())
  sirket          String?
  policeNo        String?
  baslangicTarihi DateTime
  bitisTarihi     DateTime
  tutar           Float?
  aktifMi         Boolean  @default(true)
  aracId          String
  sirketId        String?
  acente          String?
  saseNo          String?
  arac            Arac     @relation(fields: [aracId], references: [id])

  @@index([aracId])
  @@index([sirketId])
}

model Muayene {
  id               String   @id @default(cuid())
  muayeneTarihi    DateTime
  gecerlilikTarihi DateTime
  aktifMi          Boolean  @default(true)
  aracId           String
  sirketId         String?
  km               Int?
  tutar            Float?
  gectiMi          Boolean  @default(true)
  saseNo           String?
  arac             Arac     @relation(fields: [aracId], references: [id])

  @@index([aracId])
  @@index([sirketId])
}

model Bakim {
  id              String         @id @default(cuid())
  bakimTarihi     DateTime
  yapilanKm       Int
  sonrakiBakimKm  Int?
  servisAdi       String?
  yapilanIslemler String?
  tutar           Float          @default(0)
  tur             BakimTuru      @default(PERIYODIK)
  aracId          String
  sirketId        String?
  kategori        ServisKategori @default(PERIYODIK_BAKIM)
  saseNo          String?
  deletedAt       DateTime?
  deletedBy       String?
  arac            Arac           @relation(fields: [aracId], references: [id])
  arizaKaydi      ArizaKaydi?

  @@index([aracId])
  @@index([sirketId])
  @@index([deletedAt])
}

model ArizaKaydi {
  id               String            @id @default(cuid())
  aracId           String
  soforId          String?           @map("kullaniciId")
  sirketId         String?
  bakimId          String?           @unique
  aciklama         String
  oncelik          ArizaOncelik      @default(ORTA)
  durum            ArizaKaydiDurumu  @default(ACIK)
  km               Int?
  servisAdi        String?
  yapilanIslemler  String?
  tutar            Float             @default(0)
  bildirimTarihi   DateTime          @default(now())
  serviseSevkTarihi DateTime?
  kapanisTarihi    DateTime?
  olusturmaTarihi  DateTime          @default(now())
  guncellemeTarihi DateTime          @default(now()) @updatedAt
  arac             Arac              @relation(fields: [aracId], references: [id])
  sofor            Kullanici?        @relation("ArizaSoforRelation", fields: [soforId], references: [id])
  bakim            Bakim?            @relation(fields: [bakimId], references: [id])

  @@index([aracId])
  @@index([soforId])
  @@index([sirketId])
  @@index([durum])
  @@index([bildirimTarihi])
}

model Ceza {
  id             String     @id @default(cuid())
  tarih          DateTime   @map("cezaTarihi")
  tutar          Float
  aciklama       String?
  odendiMi       Boolean    @default(false)
  aracId         String
  soforId        String?    @map("kullaniciId")
  sirketId       String?
  km             Int?
  sonOdemeTarihi DateTime?
  plaka          String?
  cezaMaddesi    String     @default("Belirtilmedi")
  saseNo         String?
  deletedAt      DateTime?
  deletedBy      String?
  arac           Arac       @relation(fields: [aracId], references: [id])
  kullanici      Kullanici? @relation("CezaSoforRelation", fields: [soforId], references: [id])

  @@index([plaka])
  @@index([soforId])
  @@index([aracId])
  @@index([sirketId])
  @@index([deletedAt])
}

model Masraf {
  id        String           @id @default(cuid())
  tarih     DateTime         @default(now())
  tur       MasrafKategorisi
  tutar     Float
  aracId    String
  aciklama  String?
  sirketId  String?
  saseNo    String?
  deletedAt DateTime?
  deletedBy String?
  arac      Arac             @relation(fields: [aracId], references: [id])

  @@index([aracId])
  @@index([sirketId])
  @@index([deletedAt])
}

model Yakit {
  id           String       @id @default(cuid())
  tarih        DateTime     @default(now())
  litre        Float
  tutar        Float
  km           Int
  istasyon     String?
  aracId       String
  sirketId     String?
  odemeYontemi OdemeYontemi @default(NAKIT)
  soforId      String?
  saseNo       String?
  arac         Arac         @relation(fields: [aracId], references: [id])
  sofor        Kullanici?   @relation("YakitSoforRelation", fields: [soforId], references: [id])

  @@index([aracId])
  @@index([sirketId])
  @@index([tarih])
  @@index([soforId])
}

model HgsYukleme {
  id       String   @id @default(cuid())
  tarih    DateTime @default(now())
  etiketNo String?
  tutar    Float
  aracId   String
  sirketId String?
  km       Int?
  saseNo   String?
  arac     Arac     @relation(fields: [aracId], references: [id])

  @@index([aracId])
  @@index([sirketId])
  @@index([tarih])
}

model ActivityLog {
  id         String             @id @default(cuid())
  actionType ActivityActionType
  entityType ActivityEntityType
  entityId   String
  summary    String
  metadata   Json?
  userId     String?
  companyId  String?
  createdAt  DateTime           @default(now())

  @@index([actionType])
  @@index([entityType])
  @@index([entityId])
  @@index([companyId])
  @@index([userId])
  @@index([createdAt])
}

model Dokuman {
  id            String      @id @default(cuid())
  ad            String
  dosyaUrl      String
  tur           DokumanTuru
  yuklemeTarihi DateTime    @default(now())
  aracId        String
  sirketId      String?
  saseNo        String?
  deletedAt     DateTime?
  deletedBy     String?
  arac          Arac        @relation(fields: [aracId], references: [id])

  @@index([aracId])
  @@index([sirketId])
  @@index([deletedAt])
}

enum Rol {
  ADMIN
  YETKILI
  SOFOR
  TEKNIK
}

enum AracDurumu {
  BOSTA
  AKTIF
  SERVISTE
  YEDEK
  ARIZALI
}

enum AracKategori {
  IS_MAKINESI
  KAMYON_TIR
  BINEK
}

enum MasrafKategorisi {
  YAKIT
  HGS_YUKLEME
  YIKAMA
  AKSESUAR
  DIGER
  BAKIM_ONARIM
  LASTIK
  TEMIZLIK
  OTOPARK
  KOPRU_OBO
}

enum DokumanTuru {
  RUHSAT
  SIGORTA
  KASKO
  SERVIS_FATURA
  DIGER
}

enum BakimTuru {
  PERIYODIK
  ARIZA
  KAPORTA
}

enum ServisKategori {
  PERIYODIK_BAKIM
  ARIZA
}

enum ArizaKaydiDurumu {
  ACIK
  SERVISTE
  TAMAMLANDI
  IPTAL
}

enum ArizaOncelik {
  DUSUK
  ORTA
  YUKSEK
  KRITIK
}

enum iller {
  ISTANBUL  @map("İSTANBUL")
  BURSA
  SANLIURFA @map("ŞANLIURFA")
  ANKARA
  DIGER     @map("DİĞER")
}

enum OnayDurumu {
  BEKLIYOR
  ONAYLANDI
  REDDEDILDI
}

enum OdemeYontemi {
  NAKIT
  TASIT_TANIMA
}

enum ActivityActionType {
  CREATE
  UPDATE
  DELETE
  RESTORE
  ARCHIVE
  LOGIN_SUCCESS
  LOGIN_FAILURE
  ROLE_CHANGE
  STATUS_CHANGE
}

enum ActivityEntityType {
  ARAC
  MASRAF
  BAKIM
  DOKUMAN
  CEZA
  KULLANICI
  OTURUM
  DIGER
}

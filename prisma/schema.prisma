generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Arac {
  id                String            @id @default(cuid())
  plaka             String            @unique
  marka             String
  model             String
  yil               Int
  bulunduguIl       String
  guncelKm          Int               @default(0)
  hgsNo             String?
  ruhsatSeriNo      String?
  durum             AracDurumu        @default(AKTIF)

  // Mevcut Şoför (1-1 Zimmet)
  sofor             Sofor?            @relation(fields: [soforId], references: [id])
  soforId           String?           @unique

  // İlişkiler
  trafikSigortasi   TrafikSigortasi[]
  kasko             Kasko[]
  muayene           Muayene[]
  bakimlar          Bakim[]
  cezalar           Ceza[]
  masraflar         Masraf[]
  soforGecmisi      SoforZimmet[]
  yakitlar          Yakit[]
  arizalar          Ariza[]
  dokumanlar        Dokuman[]

  olusturmaTarihi   DateTime          @default(now())
  guncellemeTarihi  DateTime          @default(now()) @updatedAt
  @@index([plaka])
  @@index([durum])
}

model Sofor {
  id          String         @id @default(cuid())
  adSoyad     String
  telefon     String?
  tcNo        String?        @unique
  
  arac        Arac?          // Mevcut zimmetli araç
  zimmetler   SoforZimmet[]  // Geçmiş tüm zimmet kayıtları
}

model SoforZimmet {
  id              String    @id @default(cuid())
  arac            Arac      @relation(fields: [aracId], references: [id])
  aracId          String
  sofor           Sofor     @relation(fields: [soforId], references: [id])
  soforId         String
  baslangic       DateTime  @default(now())
  bitis           DateTime?
  baslangicKm     Int       // Aracı teslim aldığı KM
  bitisKm         Int?      // Aracı teslim ettiği KM
  notlar          String?

  @@index([aracId])
  @@index([soforId])
}

model TrafikSigortasi {
  id              String   @id @default(cuid())
  sirket          String?
  policeNo        String?
  baslangicTarihi DateTime
  bitisTarihi     DateTime
  tutar           Float?
  aktifMi         Boolean  @default(true)

  arac            Arac     @relation(fields: [aracId], references: [id])
  aracId          String

  @@index([aracId])
}

model Kasko {
  id              String   @id @default(cuid())
  sirket          String?
  policeNo        String?
  baslangicTarihi DateTime
  bitisTarihi     DateTime
  tutar           Float?
  aktifMi         Boolean  @default(true)

  arac            Arac     @relation(fields: [aracId], references: [id])
  aracId          String

  @@index([aracId])
}

model Muayene {
  id               String   @id @default(cuid())
  muayeneTarihi    DateTime
  gecerlilikTarihi DateTime
  istasyon         String?
  aktifMi          Boolean  @default(true)

  arac             Arac     @relation(fields: [aracId], references: [id])
  aracId           String

  @@index([aracId])
}

model Bakim {
  id              String   @id @default(cuid())
  bakimTarihi     DateTime
  yapilanKm       Int
  sonrakiBakimKm  Int?
  servisAdi       String?
  yapilanIslemler String?  @db.Text
  tutar           Float    @default(0)

  arac            Arac     @relation(fields: [aracId], references: [id])
  aracId          String

  @@index([aracId])
}

model Ceza {
  id          String   @id @default(cuid())
  cezaTarihi  DateTime
  tutar       Float
  aciklama    String?
  odendiMi    Boolean  @default(false)

  arac        Arac     @relation(fields: [aracId], references: [id])
  aracId      String

  @@index([aracId])
}

model Masraf {
  id      String           @id @default(cuid())
  tarih   DateTime         @default(now())
  tur     MasrafKategorisi
  tutar   Float

  arac    Arac             @relation(fields: [aracId], references: [id])
  aracId  String

  @@index([aracId])
}

model Yakit {
  id       String   @id @default(cuid())
  tarih    DateTime @default(now())
  litre    Float
  tutar    Float
  km       Int      // Yakıt alındığı andaki KM
  istasyon String?

  arac     Arac     @relation(fields: [aracId], references: [id])
  aracId   String

  @@index([aracId])
  @@index([tarih])
}

model Ariza {
  id           String      @id @default(cuid())
  aciklama     String
  arizaTarihi  DateTime    @default(now())
  durum        ArizaDurumu @default(ACIK)
  servis       String?
  tahminiTutar Float?

  arac         Arac        @relation(fields: [aracId], references: [id])
  aracId       String

  @@index([aracId])
}

model Dokuman {
  id            String      @id @default(cuid())
  ad            String
  dosyaUrl      String
  tur           DokumanTuru
  yuklemeTarihi DateTime    @default(now())

  arac          Arac        @relation(fields: [aracId], references: [id])
  aracId        String

  @@index([aracId])
}

// ENUMLAR
enum AracDurumu {
  AKTIF
  SERVISTE
  YEDEK
  ARIZALI
  SATILDI
}

enum MasrafKategorisi {
  YAKIT
  HGS_YUKLEME
  YIKAMA
  AKSESUAR
  DIGER
}

enum ArizaDurumu {
  ACIK
  TAMIRDE
  COZULDU
  PARCA_BEKLIYOR
}

enum DokumanTuru {
  RUHSAT
  SIGORTA
  KASKO
  SERVIS_FATURA
  DIGER
}

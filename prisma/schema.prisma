generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Sirket {
  id          String      @id @default(cuid())
  ad          String
  bulunduguIl iller       @default(BURSA)
  vergiNo     String?
  kullanicilar Kullanici[]
  araclar      Arac[]
  
  olusturmaTarihi DateTime @default(now())
}

model Arac {
  id                String            @id @default(cuid())
  plaka             String            @unique
  marka             String
  model             String
  yil               Int
  bulunduguIl       iller             @default(BURSA)
  guncelKm          Int               @default(0)
  hgsNo             String?
  ruhsatSeriNo      String?
  durum             AracDurumu        @default(AKTIF)
  kategori          AracKategori      @default(BINEK)

  // Mevcut Şoför (1-1 Zimmet)
  kullanici         Kullanici?        @relation(fields: [kullaniciId], references: [id])
  kullaniciId       String?           @unique

  // Şirket
  sirket            Sirket?           @relation(fields: [sirketId], references: [id])
  sirketId          String?

  // İlişkiler
  trafikSigortasi   TrafikSigortasi[]
  kasko             Kasko[]
  muayene           Muayene[]
  bakimlar          Bakim[]
  cezalar           Ceza[]
  masraflar         Masraf[]
  kullaniciGecmisi  KullaniciZimmet[]
  yakitlar          Yakit[]
  arizalar          Ariza[]
  dokumanlar        Dokuman[]
  hgsYuklemeler     HgsYukleme[]

  olusturmaTarihi   DateTime          @default(now())
  guncellemeTarihi  DateTime          @default(now()) @updatedAt
  @@index([plaka])
  @@index([durum])
  @@index([sirketId])
}

model Kullanici {
  id          String         @id @default(cuid())
  ad          String
  soyad       String
  telefon     String?
  tcNo        String?        @unique
  sehir       iller?
  eposta      String?        @unique
  sifre       String?
  rol         Rol            @default(SOFOR)
  
  onayDurumu  OnayDurumu     @default(BEKLIYOR)
  
  sirket      Sirket?        @relation(fields: [sirketId], references: [id])
  sirketId    String?

  arac        Arac?          // Mevcut zimmetli araç
  zimmetler   KullaniciZimmet[]  // Geçmiş tüm zimmet kayıtları
  cezalar     Ceza[]
  
  @@index([sirketId])
}

model KullaniciZimmet {
  id              String    @id @default(cuid())
  arac            Arac      @relation(fields: [aracId], references: [id])
  aracId          String
  kullanici       Kullanici @relation(fields: [kullaniciId], references: [id])
  kullaniciId     String
  baslangic       DateTime  @default(now())
  bitis           DateTime?
  baslangicKm     Int       // Aracı teslim aldığı KM
  bitisKm         Int?      // Aracı teslim ettiği KM
  notlar          String?

  @@index([aracId])
  @@index([kullaniciId])
}

model TrafikSigortasi {
  id              String   @id @default(cuid())
  sirket          String?
  policeNo        String?
  baslangicTarihi DateTime
  bitisTarihi     DateTime
  tutar           Float?
  aktifMi         Boolean  @default(true)

  arac            Arac     @relation(fields: [aracId], references: [id])
  aracId          String
  sirketId        String?

  @@index([aracId])
  @@index([sirketId])
}

model Kasko {
  id              String   @id @default(cuid())
  sirket          String?
  policeNo        String?
  baslangicTarihi DateTime
  bitisTarihi     DateTime
  tutar           Float?
  aktifMi         Boolean  @default(true)

  arac            Arac     @relation(fields: [aracId], references: [id])
  aracId          String
  sirketId        String?

  @@index([aracId])
  @@index([sirketId])
}

model Muayene {
  id               String   @id @default(cuid())
  muayeneTarihi    DateTime
  gecerlilikTarihi DateTime
  istasyon         String?
  km               Int?     // Muayene anındaki KM
  aktifMi          Boolean  @default(true)

  arac             Arac     @relation(fields: [aracId], references: [id])
  aracId           String
  sirketId         String?

  @@index([aracId])
  @@index([sirketId])
}

model Bakim {
  id              String    @id @default(cuid())
  bakimTarihi     DateTime
  yapilanKm       Int
  sonrakiBakimKm  Int?
  servisAdi       String?
  yapilanIslemler String?   @db.Text
  tutar           Float     @default(0)
  tur             BakimTuru @default(PERIYODIK)

  arac            Arac      @relation(fields: [aracId], references: [id])
  aracId          String
  sirketId        String?

  @@index([aracId])
  @@index([sirketId])
}

model Ceza {
  id          String   @id @default(cuid())
  cezaTarihi  DateTime
  tutar       Float
  km          Int?     // Ceza anındaki KM (Opsiyonel)
  aciklama    String?
  odendiMi    Boolean  @default(false)

  arac        Arac     @relation(fields: [aracId], references: [id])
  aracId      String

  kullanici   Kullanici? @relation(fields: [kullaniciId], references: [id])
  kullaniciId String?
  sirketId    String?

  @@index([aracId])
  @@index([kullaniciId])
  @@index([sirketId])
}

model Masraf {
  id       String           @id @default(cuid())
  tarih    DateTime         @default(now())
  tur      MasrafKategorisi
  tutar    Float
  aciklama String?

  arac     Arac             @relation(fields: [aracId], references: [id])
  aracId   String
  sirketId String?

  @@index([aracId])
  @@index([sirketId])
}

model Yakit {
  id             String        @id @default(cuid())
  tarih          DateTime      @default(now())
  litre          Float
  tutar          Float
  km             Int           // Yakıt alındığı andaki KM
  istasyon       String?
  odemeYontemi   OdemeYontemi  @default(NAKIT)

  arac           Arac          @relation(fields: [aracId], references: [id])
  aracId         String
  sirketId       String?

  @@index([aracId])
  @@index([sirketId])
  @@index([tarih])
}

model HgsYukleme {
  id        String   @id @default(cuid())
  tarih     DateTime @default(now())
  etiketNo  String?
  tutar     Float
  km        Int?     // Yükleme anındaki KM

  arac      Arac     @relation(fields: [aracId], references: [id])
  aracId    String
  sirketId  String?

  @@index([aracId])
  @@index([sirketId])
  @@index([tarih])
}

model Ariza {
  id           String      @id @default(cuid())
  aciklama     String
  arizaTarihi  DateTime    @default(now())
  durum        ArizaDurumu @default(ACIK)
  servis       String?
  tahminiTutar Float?

  arac         Arac        @relation(fields: [aracId], references: [id])
  aracId       String
  sirketId     String?

  @@index([aracId])
  @@index([sirketId])
}

model Dokuman {
  id            String      @id @default(cuid())
  ad            String
  dosyaUrl      String
  tur           DokumanTuru
  yuklemeTarihi DateTime    @default(now())

  arac          Arac        @relation(fields: [aracId], references: [id])
  aracId        String
  sirketId      String?

  @@index([aracId])
  @@index([sirketId])
}

// ENUMLAR
enum Rol {
  ADMIN
  YONETICI
  MUDUR
  MUHASEBECI
  YETKİLİ
  SOFOR
}

enum AracDurumu {
  BOSTA
  AKTIF
  SERVISTE
  YEDEK
  ARIZALI
}

enum AracKategori {
  IS_MAKINESI
  KAMYON_TIR
  BINEK
}

enum MasrafKategorisi {
  YAKIT
  HGS_YUKLEME
  YIKAMA
  AKSESUAR
  BAKIM_ONARIM
  LASTIK
  TEMIZLIK
  OTOPARK
  KOPRU_OBO
  DIGER
}

enum ArizaDurumu {
  ACIK
  TAMIRDE
  COZULDU
  PARCA_BEKLIYOR
}

enum DokumanTuru {
  RUHSAT
  SIGORTA
  KASKO
  SERVIS_FATURA
  DIGER
}

enum BakimTuru {
  PERIYODIK
  ARIZA
  KAPORTA
}

enum iller {
  İSTANBUL
  BURSA
  ŞANLIURFA
  ANKARA
  DİĞER
}

enum OnayDurumu {
  BEKLIYOR
  ONAYLANDI
  REDDEDILDI
}

enum OdemeYontemi {
  TASIT_TANIMA
  NAKIT
  
}
